{
  "name": "@byos3/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "docs:build": "bun run scripts/build-docs.ts",
    "docs:deploy": "bun run docs:build && wrangler deploy --config wrangler.docs.jsonc",
    "test": "bun test"
  },
  "dependencies": {
    "@byos3/auth": "workspace:*",
    "@byos3/core": "workspace:*",
    "@byos3/crypto": "workspace:*",
    "@byos3/db": "workspace:*",
    "@byos3/logging": "workspace:*",
    "@byos3/protocol": "workspace:*",
    "@byos3/s3": "workspace:*",
    "@byos3/services": "workspace:*",
    "@hono/zod-openapi": "^1.4.0",
    "better-auth": "^1.6.20",
    "drizzle-orm": "latest",
    "hono": "^4.12.0",
    "zod": "^4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250906.0",
    "wrangler": "^4.70.0"
  }
}
