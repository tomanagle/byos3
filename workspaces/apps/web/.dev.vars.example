# Local dev secrets for the web Worker. Copy to `.dev.vars` (gitignored) and fill in, or just run
# `bun run secrets:setup` from the repo root to generate it. Production sets these as GitHub Actions
# secrets (see README.md / .github/workflows/deploy.yml). Read automatically by wrangler dev / vite.

# Cloudflare Turnstile PUBLIC test secret (always passes) - local dev only.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Platform secrets. Generate with: openssl rand -base64 32
# CREDENTIAL_ENCRYPTION_KEY + BETTER_AUTH_SECRET MUST match workspaces/apps/api/.dev.vars
# (both Workers bind the same D1).
CREDENTIAL_ENCRYPTION_KEY=
BETTER_AUTH_SECRET=

# Billing (optional - leave blank for core local dev). Set STRIPE_SECRET_KEY to your Stripe SANDBOX
# secret key; the `stripe` dev container (dev/stripe-setup.sh) then ensures the product/prices exist
# and AUTO-FILLS the three vars below into your .dev.vars. See agents/docs/billing.md.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# GitHub OAuth (optional - leave blank to use email/password only). Create an OAuth App at
# github.com/settings/developers with callback http://localhost:4500/api/auth/callback/github.
# Both must be set to enable the "Continue with GitHub" button. See agents/docs/auth.md.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
