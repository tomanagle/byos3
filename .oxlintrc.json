{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "import", "unicorn"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "react/react-in-jsx-scope": "off"
  },
  "env": { "browser": true, "es2024": true },
  "ignorePatterns": [
    "**/routeTree.gen.ts",
    "**/worker-configuration.d.ts",
    "**/dist/**",
    "**/.wrangler/**",
    "**/.output/**"
  ]
}
