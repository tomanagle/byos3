# Dependencies & build output
node_modules/
dist/
dist-docs/
.output/
.wrangler/
*.tsbuildinfo

# Secrets - NEVER commit local secrets. Local dev uses plaintext .dev.vars (generated by
# `bun run secrets:setup`); production secrets are set as GitHub Actions secrets (see deploy.yml).
# `.dev.vars.example` is the committed template, so it is exempted below.
.dev.vars
.dev.vars.*
!.dev.vars.example

# Local env files
.env
.env.*
!.env.example

# OS / editor
.DS_Store
*.log
