# Reference for the PLATFORM secrets the Worker needs. Committed; keep values EMPTY.
#
# IMPORTANT: these are OUR secrets (the Worker's own). They are NOT end-user
# bucket credentials — those are entered by users at runtime and envelope-encrypted
# into D1 by packages/crypto using CREDENTIAL_ENCRYPTION_KEY. See agents/docs/secrets.md
# and agents/docs/storage-byo-s3.md.
#
# Don't edit this file to add real values. Run:  bun run secrets:setup
# which prompts you and writes an encrypted secrets/local.sops.env + a .dev.vars.

# Root key packages/crypto uses to envelope-encrypt user bucket creds (auto-generated)
CREDENTIAL_ENCRYPTION_KEY=
# Better Auth session secret (auto-generated)
BETTER_AUTH_SECRET=
# Stripe — use test values locally (sk_test_… / whsec_…)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
